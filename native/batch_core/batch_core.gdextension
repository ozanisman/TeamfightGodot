[configuration]
entry_symbol = "batch_core_library_init"
compatibility_minimum = "4.6"
reloadable = true

[libraries]
windows.debug.x86_64 = "res://native/batch_core/bin/batch_core.windows.debug.x86_64.dll"
windows.release.x86_64 = "res://native/batch_core/bin/batch_core.windows.release.x86_64.dll"
