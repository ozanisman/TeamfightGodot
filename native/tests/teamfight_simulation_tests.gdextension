[configuration]
entry_symbol = "teamfight_simulation_tests_library_init"
compatibility_minimum = "4.6"
reloadable = true

[libraries]
windows.debug.x86_64 = "res://native/bin/tests/teamfight_simulation_tests.dll"
windows.release.x86_64 = "res://native/bin/tests/teamfight_simulation_tests.dll"
linux.debug.x86_64 = "res://native/bin/tests/teamfight_simulation_tests.so"
linux.release.x86_64 = "res://native/bin/tests/teamfight_simulation_tests.so"
macos.debug = "res://native/bin/tests/teamfight_simulation_tests.dylib"
macos.release = "res://native/bin/tests/teamfight_simulation_tests.dylib"
